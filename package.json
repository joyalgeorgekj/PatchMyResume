{
  "name": "patchmyresume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "prettier:src": "prettier --write src/",
    "sync:pm": "npm install && npm run sync:pm:convert",
    "sync:pm:convert": "npm run sync:pm:to-yarn && npm run sync:pm:to-pnpm",
    "sync:pm:to-yarn": "npx synp --npm-to-yarn && yarn install --check-files",
    "sync:pm:to-pnpm": "pnpm import && pnpm install"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "appwrite": "^20.1.0",
    "next": "15.5.9",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "node-appwrite": "^17.2.0",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "synp": "^1.9.14",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
